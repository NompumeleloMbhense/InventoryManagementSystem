@using ClientApp.Services
@using ClientApp.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inherits LayoutComponentBase
@inject AuthTokenService TokenService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="d-flex min-vh-100">

    <!-- Sidebar -->
    <AuthorizeView>
        <Authorized>
            <div class="sidebar bg-dark text-white p-3">
                <h5 class="fw-bold mb-4">Manager</h5>

                <ul class="nav flex-column">

                    <li class="nav-item mb-2">
                        <NavLink href="/" class="nav-link text-white" Match="NavLinkMatch.All">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard
                        </NavLink>
                    </li>

                    <li class="nav-item mb-2">
                        <NavLink href="/products" class="nav-link text-white">
                            <i class="bi bi-box-seam me-2"></i> Products
                        </NavLink>
                    </li>

                    <li class="nav-item mb-2">
                        <NavLink href="/suppliers" class="nav-link text-white">
                            <i class="bi bi-people me-2"></i> Suppliers
                        </NavLink>
                    </li>

                    <li class="nav-item mt-4">
                        <button class="btn btn-outline-light w-100" @onclick="Logout">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </button>
                    </li>

                </ul>
            </div>
        </Authorized>
    </AuthorizeView>

    <!-- Main Content Area -->
    <div class="flex-grow-1 d-flex flex-column">

        <!-- Topbar -->
        <nav class="topbar bg-white shadow-sm px-4 py-2 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-semibold">Inventory Management System</h6>

            <AuthorizeView>
                <Authorized>
                    <span class="text-muted">
                        Welcome, @GetUserName(@context.User)
                    </span>
                </Authorized>
            </AuthorizeView>
        </nav>

        <!-- Page Content -->
        <main class="flex-grow-1 p-4 dashboard-bg">
            @Body
        </main>

        <!-- Footer -->
        <footer class="bg-light text-center py-2 small text-muted">
            © @DateTime.Now.Year - Inventory Management System
        </footer>

    </div>

</div>

@code
{
    private string? GetUserName(ClaimsPrincipal user)
    {
        return user.FindFirst("fullName")?.Value
           ?? user.FindFirst(ClaimTypes.Name)?.Value
           ?? "User";
    }

    private async Task Logout()
    {
        if (AuthStateProvider is JwtAuthenticationStateProvider jwtProvider)
        {
            await jwtProvider.MarkUserAsLoggedOut();
        }

        Navigation.NavigateTo("/login", replace: true);
    }
}