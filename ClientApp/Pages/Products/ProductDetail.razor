@page "/products/{ProductId:int}" 
@using SharedApp.Dto
@using ClientApp.Services
@inject ProductService ProductService
@inject NavigationManager Navigation

<h3 class="text-2xl font-bold mb-4">Product Details</h3>

@if (product is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card p-4 shadow-sm border-0">
        <h4>@product.Name</h4>
        <hr />
        <p><strong>Price:</strong> R @product.Price.ToString("N2")</p>
        <p><strong>Stock:</strong> @product.Stock</p>
        <p><strong>Category:</strong> @product.Category</p>
        <p><strong>Supplier:</strong> @product.SupplierName</p>
        <p><strong>Location:</strong> @product.SupplierLocation</p>

        <button class="btn btn-secondary mt-3" @onclick='() => Navigation.NavigateTo("/products")'>Back to Products</button>
    </div>
}

@code {
    [Parameter] public int ProductId { get; set; } 
    private ProductReadDto? product; 

    protected override async Task OnInitializedAsync()
    {
        product = await ProductService.GetByIdAsync(ProductId);
    }
}