@page "/products"
@attribute [Authorize]
@using SharedApp.Dto
@using ClientApp.Services
@inject NavigationManager Navigation
@inject ProductService ProductService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Products</h3>
    @if (isAdmin)
    {
        <button class="btn btn-success" @onclick='() => Navigation.NavigateTo("/products/add")'>
            + Add Product
        </button>
    }
</div>

<!-- Search & Filter Section -->
<div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-5">
                <input type="text" class="form-control" placeholder="Search by product name..." @bind="searchQuery" />
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="selectedCategory">
                    <option value="">All Categories</option>
                    <option value="Tech & Electronics">Tech & Electronics</option>
                    <option value="Home & Lifestyle">Home & Lifestyle</option>
                    <option value="Office & Accessories">Office & Accessories</option>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button class="btn btn-primary w-100" @onclick="PerformSearch">Search</button>
                <button class="btn btn-outline-secondary w-100" @onclick="ClearSearch">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (products is null)
{
    <p><em>Loading inventory...</em></p>
}
else
{
    <div class="table-responsive bg-white shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Category</th>
                    @if (isAdmin) { <th class="text-center">Actions</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var p in products.Data)
                {
                    <tr>
                        <td>
                            <a href="/products/@p.ProductId" class="text-decoration-none fw-bold">@p.Name</a>
                        </td>
                        <td>R @p.Price.ToString("N2")</td>
                        <td>
                            <span class="badge @(p.Stock <= 5 ? "bg-danger" : "bg-success")">
                                @p.Stock units
                            </span>
                        </td>
                        <td>@p.Category</td>
                        @if (isAdmin)
                        {
                            <td class="text-center">
                                @* --- ORANGE EDIT BUTTON --- *@
                                <button class="btn btn-sm fw-bold me-2" 
                                        style="background-color: #ff8c00; color: white; border: none;"
                                        @onclick='() => Navigation.NavigateTo($"/products/edit/{p.ProductId}")'>
                                    Edit
                                </button>
                                @* --- RED DELETE BUTTON --- *@
                                <button class="btn btn-sm btn-danger fw-bold" 
                                        @onclick="() => DeleteProduct(p.ProductId, p.Name)">
                                    Delete
                                </button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (string.IsNullOrWhiteSpace(searchQuery) && string.IsNullOrWhiteSpace(selectedCategory))
    {
        <div class="d-flex justify-content-between align-items-center mt-3">
            <button class="btn btn-outline-primary btn-sm" @onclick="PrevPage" disabled="@(pageNumber <= 1)">Previous</button>
            <span class="small text-muted">Page @pageNumber of @products.TotalPages</span>
            <button class="btn btn-outline-primary btn-sm" @onclick="NextPage" disabled="@(pageNumber >= products.TotalPages)">Next</button>
        </div>
    }
}

@code {
    private PagedResponse<ProductReadDto>? products;
    private bool isAdmin = false;
    private int pageNumber = 1;
    private string searchQuery = "";
    private string selectedCategory = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole("Admin");
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync() => products = await ProductService.GetPaginatedAsync(pageNumber, 8);

    private async Task PerformSearch()
    {
        var results = await ProductService.SearchAsync(searchQuery, selectedCategory);
        products = new PagedResponse<ProductReadDto> { Data = results, TotalPages = 1, PageNumber = 1 };
    }

    private async Task ClearSearch()
    {
        searchQuery = ""; selectedCategory = ""; pageNumber = 1;
        await LoadProductsAsync();
    }

    private async Task NextPage() { pageNumber++; await LoadProductsAsync(); }
    private async Task PrevPage() { pageNumber--; await LoadProductsAsync(); }

    private async Task DeleteProduct(int id, string name)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirmDelete", $"Remove {name}?"))
        {
            await ProductService.DeleteAsync(id);
            await LoadProductsAsync();
        }
    }
}