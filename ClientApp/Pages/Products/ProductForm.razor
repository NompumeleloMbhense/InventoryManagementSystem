@using SharedApp.Dto
@using ClientApp.Services
@inject SupplierService SupplierService
@inject NavigationManager Navigation

<EditForm Model="@FormModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />

    <div class="card shadow-sm p-4">
        <div class="mb-3">
            <label class="form-label fw-bold">Product Name</label>
            <InputText class="form-control" @bind-Value="FormModel.Name" />
            <ValidationMessage For="@(() => FormModel.Name)" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Price (R)</label>
                <InputNumber class="form-control" @bind-Value="FormModel.Price" />
                <ValidationMessage For="@(() => FormModel.Price)" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Stock</label>
                <InputNumber class="form-control" @bind-Value="FormModel.Stock" />
                <ValidationMessage For="@(() => FormModel.Stock)" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Category</label>
            <InputSelect class="form-select" @bind-Value="FormModel.Category">
                <option value="">-- Select Category --</option>
                <option value="Tech & Electronics">Tech & Electronics</option>
                <option value="Home & Lifestyle">Home & Lifestyle</option>
                <option value="Office & Accessories">Office & Accessories</option>
            </InputSelect>
            <ValidationMessage For="@(() => FormModel.Category)" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Supplier</label>
            @if (suppliers is null)
            {
                <p class="small text-muted">Loading suppliers...</p>
            }
            else
            {
                <InputSelect @bind-Value="FormModel.SupplierId" class="form-select">
                    <option value="0">-- Select Supplier --</option>
                    @foreach (var s in suppliers)
                    {
                        <option value="@s.SupplierId">@s.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => FormModel.SupplierId)" />
            }
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary me-2">@SubmitButtonText</button>
            <button type="button" class="btn btn-secondary" @onclick='() => Navigation.NavigateTo("/products")'>Cancel</button>
        </div>
    </div>
</EditForm>

@code {
    [Parameter] public ProductCreateDto FormModel { get; set; } = new();
    [Parameter] public string SubmitButtonText { get; set; } = "Save";
    [Parameter] public EventCallback OnValidSubmitForm { get; set; }

    private IEnumerable<SupplierReadDto>? suppliers;

    protected override async Task OnInitializedAsync()
    {
        var response = await SupplierService.GetPaginatedAsync(1, 100);
        suppliers = response?.Data;
    }

    private async Task HandleValidSubmit() => await OnValidSubmitForm.InvokeAsync();
}