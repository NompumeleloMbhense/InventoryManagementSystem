@page "/suppliers/{SupplierId:int}"
@using SharedApp.Dto
@using ClientApp.Services
@inject SupplierService SupplierService
@inject NavigationManager Navigation

<h3 class="fw-bold mb-4">Supplier Details</h3>

@if (supplier is null)
{
    <p><em>Loading details...</em></p>
}
else
{
    <div class="card shadow-sm border-0 p-4 mb-4">
        <div class="row">
            <div class="col-md-4"><strong>Name:</strong> <p>@supplier.Name</p></div>
            <div class="col-md-4"><strong>Location:</strong> <p>@supplier.Location</p></div>
            <div class="col-md-4"><strong>Email:</strong> <p>@supplier.Email</p></div>
        </div>
    </div>

    <h4 class="fw-bold mt-4">Assigned Products</h4>
    @if (supplier.Products.Any())
    {
        <table class="table table-hover table-striped bg-white shadow-sm rounded">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Category</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in supplier.Products)
                {
                    <tr>
                        <td>@p.Name</td>
                        <td>R @p.Price.ToString("N2")</td>
                        <td>@p.Stock</td>
                        <td>@p.Category</td>
                        <td>
                            <span class="badge @(p.Available ? "bg-success" : "bg-danger")">
                                @(p.Available ? "Available" : "Out of Stock")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">This supplier has no products yet.</div>
    }

    <button class="btn btn-secondary mt-3" @onclick='() => Navigation.NavigateTo("/suppliers")'>
        <i class="bi bi-arrow-left"></i> Back to List
    </button>
}

@code {
    [Parameter] public int SupplierId { get; set; }
    private SupplierWithProductsDto? supplier;

    protected override async Task OnInitializedAsync()
    {
        supplier = await SupplierService.GetByIdAsync(SupplierId);
        if (supplier is null) Navigation.NavigateTo("/suppliers");
    }
}