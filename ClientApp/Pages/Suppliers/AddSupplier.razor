@page "/suppliers/add"
@using SharedApp.Dto
@using ClientApp.Services
@inject SupplierService SupplierService
@inject NavigationManager Navigation

<h3 class="mb-4">Add New Supplier</h3>
<SupplierForm FormModel="supplier" SubmitButtonText="Create Supplier" OnValidSubmitForm="HandleAdd" />

@code {
    private SupplierCreateDto supplier = new();

    private async Task HandleAdd()
    {
        var success = await SupplierService.CreateAsync(supplier);
        if (success) Navigation.NavigateTo("/suppliers?added=true");
    }
}