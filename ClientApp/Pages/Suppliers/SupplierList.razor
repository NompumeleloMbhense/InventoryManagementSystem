@page "/suppliers"
@attribute [Authorize]
@using SharedApp.Dto
@using ClientApp.Services
@inject SupplierService SupplierService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Suppliers</h3>
    @if (isAdmin)
    {
        <button class="btn btn-success" @onclick='() => Navigation.NavigateTo("/suppliers/add")'>
            + Add Supplier
        </button>
    }
</div>

<div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-8">
                <input class="form-control" placeholder="Search suppliers..." @bind="searchTerm" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button class="btn btn-primary w-100" @onclick="Search">Search</button>
                <button class="btn btn-outline-secondary w-100" @onclick="ClearSearch">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (suppliers is null)
{
    <p><em>Loading suppliers...</em></p>
}
else
{
    <div class="table-responsive bg-white shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Location</th>
                    <th>Email</th>
                    @if (isAdmin)
                    {
                        <th class="text-center">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var s in suppliers.Data)
                {
                    <tr>
                        <td>
                            <a href="/suppliers/@s.SupplierId" class="text-decoration-none fw-bold">@s.Name</a>
                        </td>
                        <td>@s.Location</td>
                        <td>@s.Email</td>
                        @if (isAdmin)
                        {
                            <td class="text-center">
                                @* --- ORANGE EDIT BUTTON --- *@
                                <button class="btn btn-sm fw-bold me-2"
                                        style="background-color: #ff8c00; color: white; border: none;"
                                        @onclick="() => Edit(s.SupplierId)">
                                    Edit
                                </button>
                                @* --- RED DELETE BUTTON --- *@
                                <button class="btn btn-sm btn-danger fw-bold" @onclick="() => DeleteSupplier(s.SupplierId, s.Name)">
                                    Delete
                                </button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <button class="btn btn-outline-primary btn-sm" @onclick="PrevPage" disabled="@(pageNumber <= 1)">Previous</button>
        <span class="small text-muted">Page @pageNumber of @suppliers.TotalPages</span>
        <button class="btn btn-outline-primary btn-sm" @onclick="NextPage"
                disabled="@(pageNumber >= suppliers.TotalPages)">Next</button>
    </div>
}

@code
{
    private PagedResponse<SupplierReadDto>? suppliers;
    private bool isAdmin = false;
    private int pageNumber = 1;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole("Admin");
        await LoadSuppliersAsync();

        // check for success messages in URL
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.ContainsKey("added"))
        {
            await ShowAlert("Success!", "Supplier has been added.", "success");
        }
        else if (query.ContainsKey("updated"))
        {
            await ShowAlert("Updated!", "Supplier changes have been saved.", "success");
        }
    }

    private async Task ShowAlert(string title, string message, string icon)
    {
        // Trigger the SweetAlert
        await JSRuntime.InvokeVoidAsync("Swal.fire", title, message, icon);
        
        // Clean the URL (remove the ?added=true) so it doesn't pop up again on refresh
        Navigation.NavigateTo("/suppliers", replace: true);
    }

    private async Task LoadSuppliersAsync() =>
        suppliers = await SupplierService.GetPaginatedAsync(pageNumber, 5, searchTerm);

    private async Task Search() { pageNumber = 1; await LoadSuppliersAsync(); }
    private async Task ClearSearch() { searchTerm = ""; pageNumber = 1; await LoadSuppliersAsync(); }
    private async Task NextPage() { pageNumber++; await LoadSuppliersAsync(); }
    private async Task PrevPage() { pageNumber--; await LoadSuppliersAsync(); }

    private void Edit(int id) => Navigation.NavigateTo($"/suppliers/edit/{id}");

    private async Task DeleteSupplier(int id, string name)
    {
        //Ask for confirmation using the script in index.html
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirmDelete", $"Are you sure you want to delete '{name}'?");
        
        if (confirmed)
        {
            var success = await SupplierService.DeleteAsync(id);
            
            if (success)
            {
                await LoadSuppliersAsync();
                
                // Show Success Alert immediately after deletion
                await JSRuntime.InvokeVoidAsync("Swal.fire",
                    "Deleted!",
                    "The supplier has been removed.",
                    "success");
            }
            else
            {
                // Handle case where supplier might have products 
                await JSRuntime.InvokeVoidAsync("Swal.fire",
                    "Error",
                    "Cannot delete supplier with active products.",
                    "error");
            }
        }
    }
}