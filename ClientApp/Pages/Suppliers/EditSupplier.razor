@page "/suppliers/edit/{id:int}"
@using SharedApp.Dto
@using ClientApp.Services
@inject SupplierService SupplierService
@inject NavigationManager Navigation

<h3 class="mb-4">Edit Supplier</h3>

@if (editModel is null)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    <SupplierForm FormModel="@editModel" SubmitButtonText="Update Changes" OnValidSubmitForm="HandleUpdate" />
}

@code {
    [Parameter] public int id { get; set; }
    private SupplierUpdateDto? editModel;

    protected override async Task OnInitializedAsync()
    {
        var supplier = await SupplierService.GetByIdAsync(id);
        if (supplier is not null)
        {
            editModel = new SupplierUpdateDto
            {
                Name = supplier.Name,
                Location = supplier.Location,
                Email = supplier.Email
            };
        }
    }

    private async Task HandleUpdate()
    {
        if (editModel != null)
        {
            var success = await SupplierService.UpdateAsync(id, editModel);
            if (success) Navigation.NavigateTo("/suppliers");
        }
    }
}