@page "/"
@using ClientApp.Services
@using ClientApp.Models
@using ClientApp.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthTokenService TokenService
@inject NavigationManager Navigation
@inject ProductService ProductService
@inject SupplierService SupplierService
@inject AuthenticationStateProvider AuthStateProvider


<AuthorizeView>

    <!--NOT AUTHENTICATED -->
    <NotAuthorized>
        <div class="text-center mt-5">
            <h1 class="display-4 text-primary fw-bold">
                Welcome to Product & Supplier Manager
            </h1>

            <p class="lead text-secondary mb-4">
                Keep your inventory organized and your suppliers up to date. All in one place.
            </p>

            <div class="d-flex justify-content-center gap-3">
                <NavLink href="/login" class="btn btn-primary btn-lg">Login</NavLink>
                <NavLink href="/register" class="btn btn-outline-secondary btn-lg">Register</NavLink>
            </div>
        </div>
    </NotAuthorized>

    <!--AUTHENTICATED -->
    <Authorized>

        @if (isLoading)
        {
            <p class="text-center mt-5"><em>Loading dashboard...</em></p>
        }
        else
        {
            <div class="container mt-5">

                <h2 class="fw-bold mb-2">
                    Welcome back,
                    <span class="text-primary">@userName</span>
                </h2>

                <p class="text-muted">
                    Here's a quick overview of your system.
                </p>

                <!-- Dashboard Cards -->
                <div class="row g-4 mt-4">

                    <!-- Products Card -->
                    <div class="col-md-4">
                        <div class="card dashboard-card shadow-sm border-0 rounded-4 p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-1">Total Products</h6>
                                    <h2 class="fw-bold mb-0">@ProductsCount</h2>
                                </div>
                                <div class="icon-circle bg-primary-subtle text-primary">
                                    <i class="bi bi-box-seam fs-4"></i>
                                </div>
                            </div>
                            <NavLink href="/products" class="btn btn-sm btn-outline-primary mt-3 w-100">
                                View Products
                            </NavLink>
                        </div>
                    </div>

                    <!-- Suppliers Card -->
                    <div class="col-md-4">
                        <div class="card dashboard-card shadow-sm border-0 rounded-4 p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-1">Total Suppliers</h6>
                                    <h2 class="fw-bold mb-0">@SuppliersCount</h2>
                                </div>
                                <div class="icon-circle bg-success-subtle text-success">
                                    <i class="bi bi-people fs-4"></i>
                                </div>
                            </div>
                            <NavLink href="/suppliers" class="btn btn-sm btn-outline-success mt-3 w-100">
                                View Suppliers
                            </NavLink>
                        </div>
                    </div>

                    <!-- Low Stock Card -->
                    <div class="col-md-4">
                        <div class="card dashboard-card shadow-sm border-0 rounded-4 p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted mb-1">Low Stock Products</h6>
                                    <h2 class="fw-bold mb-0">@LowStockCount</h2>
                                </div>
                                <div class="icon-circle bg-danger-subtle text-danger">
                                    <i class="bi bi-exclamation-triangle fs-4"></i>
                                </div>
                            </div>

                            <NavLink href="/products" class="btn btn-sm btn-outline-danger mt-3 w-100">
                                View Products
                            </NavLink>
                        </div>
                    </div>
                </div>


                <!-- Quick Actions - Admins only-->
                @if (user?.IsInRole("Admin") == true)
                {
                    <div class="mt-5">

                        <h5 class="mb-3">Quick Actions</h5>

                        <div class="row g-3">

                            <!-- Add Product -->
                            <div class="col-md-3">
                                <NavLink href="/products/add" class="text-decoration-none">
                                    <div class="card shadow-sm border-0 text-center p-3 quick-action-card">
                                        <i class="bi bi-plus-circle fs-2 text-primary mb-2"></i>
                                        <div class="fw-semibold">Add Product</div>
                                    </div>
                                </NavLink>
                            </div>

                            <!-- Add Supplier -->
                            <div class="col-md-3">
                                <NavLink href="/suppliers/add" class="text-decoration-none">
                                    <div class="card shadow-sm border-0 text-center p-3 quick-action-card">
                                        <i class="bi bi-person-plus fs-2 text-success mb-2"></i>
                                        <div class="fw-semibold">Add Supplier</div>
                                    </div>
                                </NavLink>
                            </div>

                            <!-- Manage Products -->
                            <div class="col-md-3">
                                <NavLink href="/products" class="text-decoration-none">
                                    <div class="card shadow-sm border-0 text-center p-3 quick-action-card">
                                        <i class="bi bi-box-seam fs-2 text-primary mb-2"></i>
                                        <div class="fw-semibold">Manage Products</div>
                                    </div>
                                </NavLink>
                            </div>

                            <!-- Manage Suppliers -->
                            <div class="col-md-3">
                                <NavLink href="/suppliers" class="text-decoration-none">
                                    <div class="card shadow-sm border-0 text-center p-3 quick-action-card">
                                        <i class="bi bi-people fs-2 text-success mb-2"></i>
                                        <div class="fw-semibold">Manage Suppliers</div>
                                    </div>
                                </NavLink>
                            </div>
                        </div>
                    </div>
                }


                <!-- Recent Activity -->
                <div class="mt-5">

                    <h5 class="mb-3">Recent Products</h5>

                    @if (RecentProducts.Any())
                    {
                        <ul class="list-group mb-4">
                            @foreach (var product in RecentProducts)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    @product.Name
                                    <span class="badge bg-primary">@product.Category</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>No recent products.</p>
                    }

                    <h5 class="mb-3">Recent Suppliers</h5>

                    @if (RecentSuppliers.Any())
                    {
                        <ul class="list-group mb-4">
                            @foreach (var supplier in RecentSuppliers)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    @supplier.Name
                                    <span class="badge bg-success">@supplier.Email</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>No recent suppliers.</p>
                    }

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

@code
{
    private bool isLoading = true;

    // Stores the logged-in user's display name
    private string userName = "User";

    private int ProductsCount = 0;
    private int SuppliersCount = 0;

    private int LowStockCount = 0;

    // Lists for recent activity display
    private List<ProductReadDto> RecentProducts = new();
    private List<SupplierReadDto> RecentSuppliers = new();

    private ClaimsPrincipal? user;

    protected override async Task OnInitializedAsync()
    {
        user = (await AuthStateProvider.GetAuthenticationStateAsync()).User;

        if (user.Identity?.IsAuthenticated == true)
        {
            userName = user.FindFirst("fullName")?.Value ??
                       user.FindFirst(ClaimTypes.Name)?.Value ?? "User";

            
            // Fetch counts from services
            ProductsCount = await ProductService.GetTotalCountAsync();
            SuppliersCount = await SupplierService.GetTotalCountAsync();

            // Fetch low stock count directly from server
            LowStockCount = await ProductService.GetLowStockCountAsync();

            RecentProducts = await ProductService.GetRecentAsync(3);
            RecentSuppliers = await SupplierService.GetRecentAsync(3);
        }

        isLoading = false;
    }
}